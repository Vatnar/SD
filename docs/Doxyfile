PROJECT_NAME           = "SDEngine"
PROJECT_BRIEF          = "Game Engine"

INPUT                  = SD include api-mainpage.md
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.hpp *.h *.c *.md

USE_MDFILE_AS_MAINPAGE = README.md

OUTPUT_DIRECTORY       = /docs_output
HTML_OUTPUT            = .

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO
GENERATE_HTMLHELP      = NO

# Extraction settings - get everything
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_LOCAL_METHODS  = YES

# Show everything
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
SHOW_INCLUDE_FILES     = YES
SHOW_USED_FILES        = YES
SHOW_COMPOUND_REFRESH  = YES
GENERATE_DEPRECATEDLIST= YES
GENERATE_MEMBERGROUP   = YES

# Search engine - full text
SEARCHENGINE           = YES
FULL_SEARCH_NAMES      = YES
SEARCH_INCLUDES        = YES
SEARCH_INCLUDE_FILES   = YES
SEARCH_OUTPUT_MATCHES = YES
ALLOW_SEARCH_SCRIPTS   = YES

# Disable compact index to show all entries
COMPACT_INDEX          = NO

# HTML settings
GENERATE_HTML          = YES
DISABLE_INDEX          = NO
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH        = 250

# Disable smart quotes to preserve search terms
HTML_DYNAMIC_MENUS    = YES
HTML_DYNAMIC_SECTIONS = YES

# Theme
HTML_EXTRA_STYLESHEET  = /theme/doxygen-awesome.css
HTML_EXTRA_STYLESHEET += /theme/doxygen-awesome-sidebar-only.css
HTML_EXTRA_FILES       = /theme/doxygen-awesome-darkmode-toggle.js
HTML_COLORSTYLE        = LIGHT
HTML_EXTRA_FILES      += .nojekyll

# Custom layout for navigation
LAYOUT_FILE            = /theme/custom-layout.xml
